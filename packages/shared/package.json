{
  "name": "@tollgate/shared",
  "version": "0.1.0",
  "description": "Shared types, JWT utilities, Solana helpers, and DB schema for Tollgate.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./jwt": {
      "types": "./dist/jwt.d.ts",
      "import": "./dist/jwt.js",
      "require": "./dist/jwt.cjs"
    },
    "./solana": {
      "types": "./dist/solana.d.ts",
      "import": "./dist/solana.js",
      "require": "./dist/solana.cjs"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js",
      "require": "./dist/db/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@solana/pay": "^0.2.5",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.4",
    "bignumber.js": "^9.1.2",
    "drizzle-orm": "^0.36.0",
    "jose": "^5.9.4",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "drizzle-kit": "^0.27.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
