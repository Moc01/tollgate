# =============================================================================
# Tollgate — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in real values.
# DO NOT commit .env.local to git.

# -----------------------------------------------------------------------------
# Core: Solana Network
# -----------------------------------------------------------------------------
SOLANA_NETWORK=devnet
# devnet USDC mint:
USDC_MINT_ADDRESS=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# mainnet USDC mint (use this in production):
# USDC_MINT_ADDRESS=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# -----------------------------------------------------------------------------
# RPC: Helius (https://dev.helius.xyz)
# -----------------------------------------------------------------------------
HELIUS_API_KEY=your-helius-api-key
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}
HELIUS_WEBHOOK_SECRET=your-webhook-secret

# -----------------------------------------------------------------------------
# Auth: Privy (https://dashboard.privy.io)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# -----------------------------------------------------------------------------
# Database: Supabase (https://supabase.com)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# AI: Anthropic (https://console.anthropic.com)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional: OpenAI for embeddings
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Tollgate JWT signing
# -----------------------------------------------------------------------------
# Generate with: pnpm tg:keygen
TOLLGATE_JWT_PRIVATE_KEY=
TOLLGATE_JWT_PUBLIC_KEY=
TOLLGATE_JWT_KID=tg-2026-04
TOLLGATE_ISSUER=https://tollgate.dev

# -----------------------------------------------------------------------------
# Settlement service URL
# -----------------------------------------------------------------------------
# Public URL of the settlement service (used by middleware to fetch JWKS)
TOLLGATE_BASE_URL=https://your-settlement.vercel.app
# In dev, run settlement locally on :3001
TOLLGATE_SETTLEMENT_URL=http://localhost:3001
NEXT_PUBLIC_TOLLGATE_SETTLEMENT_URL=http://localhost:3001
# Optional: Restrict dashboard endpoint-registration to a shared secret
TOLLGATE_DASHBOARD_API_KEY=
# Dev: skip on-chain tx verification (set to 'true' for local dev / e2e tests)
TOLLGATE_SKIP_ONCHAIN_VERIFY=false

# -----------------------------------------------------------------------------
# Curio demo agent
# -----------------------------------------------------------------------------
# Base58-encoded Ed25519 private key for Curio's Solana wallet.
# Generate with: pnpm tg:keygen  (or: solana-keygen new --no-bip39-passphrase)
# Fund on devnet with: pnpm tg:airdrop-usdc
CURIO_AGENT_SECRET_KEY=
# Set to 'true' to skip real on-chain payments in dev (simulated mode)
CURIO_SIMULATE_PAYMENTS=true

# -----------------------------------------------------------------------------
# Examples service
# -----------------------------------------------------------------------------
# Base URL of the examples paid-API service (used by Curio's tool definitions)
EXAMPLES_BASE_URL=http://localhost:4001
# Solana wallet that receives payments for all example endpoints
EXAMPLES_RECIPIENT_WALLET=11111111111111111111111111111111

# -----------------------------------------------------------------------------
# Optional: MoonPay for off-ramp (post-MVP)
# -----------------------------------------------------------------------------
MOONPAY_API_KEY=

# -----------------------------------------------------------------------------
# Optional: Observability
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com
SENTRY_DSN=
