{
  "name": "settlement",
  "version": "0.1.0",
  "private": true,
  "description": "Tollgate settlement service — issues access tokens after observing on-chain USDC payments.",
  "type": "module",
  "exports": {
    "./app": "./src/app.ts",
    "./config": "./src/lib/config.ts",
    "./store": "./src/lib/store.ts"
  },
  "scripts": {
    "dev": "tsx watch dev-server.ts",
    "build": "echo 'settlement: build handled by @vercel/node at deploy time'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "deploy": "vercel --prod"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.2",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.4",
    "@tollgate/shared": "workspace:*",
    "@vercel/node": "^3.2.24",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
